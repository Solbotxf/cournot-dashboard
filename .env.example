# Proxy: Upstream API for /api/proxy routes (server-side)
UPSTREAM_API_BASE=https://dev-interface.cournot.ai/play/polymarket

# Playground: Set to "true" to route playground API calls to localhost:8000
NEXT_PUBLIC_ENABLE_PLAYGROUND_LOCALHOST_MODE=false

# Auth: Set to "true" to auto-login with a test admin code (dev only)
NEXT_PUBLIC_ENABLE_TEST_AUTH=false
